# Shell scripts must keep LF line endings regardless of the contributor's platform/config:
# a CRLF shebang breaks execution in the Linux CI containers (`/usr/bin/env: 'bash\r'`).
*.sh text eol=lf

# The harness YAML (compose + Maestro flows + workflow) is consumed only on Linux CI; keep it LF
# too so a Windows checkout can't introduce CRLF into files the runner parses.
*.yaml text eol=lf
*.yml text eol=lf
